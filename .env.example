# Copy to .env and fill in. .env is gitignored.

# Tolgee — translation management.
# Generate at https://app.tolgee.io/account/apiKeys
# Used by `pnpm sync-i18n` (Node-side only — never sent to browser).
TOLGEE_API_URL=https://app.tolgee.io
TOLGEE_API_KEY=tgpak_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
