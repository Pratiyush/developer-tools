tools/
.playwright-mcp/
launch.json

# Tolgee — synced translation JSON. Generated by `pnpm sync-i18n`.
# Bundled into the production build at compile time, but the source-of-truth
# lives in Tolgee — no need to commit the cache.
src/locales/_synced/
playwright-report/
test-results/
