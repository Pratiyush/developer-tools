# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Test / coverage
coverage/
.nyc_output/

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Env files
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Claude / AI assistant artifacts (private to local dev — never push)
# NOTE: the tracked `memory/` folder at the repo root IS intentional team docs.
# Do NOT add `memory/` here. These patterns guard against private/scratch leaks.
.claude/cache/
.claude/local/
.claude/sessions/
.claude/projects/
.claude/state/
*.private.md
*.scratch.md
.scratch/

# Marketing artifacts (LinkedIn drafts, social cards, 100-day plan — local only)
marketing/

# Reference / exploration / out-of-scope folders (local-only, never push)
.analysis/
tools/
.playwright-mcp/
launch.json

# Tolgee — synced translation JSON. Generated by `pnpm sync-i18n`.
# Bundled into the production build at compile time, but the source-of-truth
# lives in Tolgee — no need to commit the cache.
src/locales/_synced/
playwright-report/
test-results/

# .claude harness config: keep settings.json + commands/, hide local-only files
.claude/settings.local.json
.claude/launch.json
